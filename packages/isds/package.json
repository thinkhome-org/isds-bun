{
  "name": "@thinkhome-org/isds",
  "version": "0.0.1",
  "description": "Complete Bun-native SDK, CLI and TUI foundation for the Czech Information System of Data Boxes",
  "type": "module",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thinkhome-org/isds-bun.git"
  },
  "bugs": {
    "url": "https://github.com/thinkhome-org/isds-bun/issues"
  },
  "homepage": "https://github.com/thinkhome-org/isds-bun#readme",
  "bin": {
    "isds": "./src/bin/isds.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./auth": "./src/auth/index.ts",
    "./config": "./src/config/profiles.ts",
    "./data-boxes": "./src/data-boxes/index.ts",
    "./raw": "./src/raw/index.ts",
    "./schemas": "./src/schemas/index.ts",
    "./crypto": "./src/crypto/index.ts",
    "./zfo": "./src/zfo/index.ts",
    "./legacy": "./src/legacy/index.ts",
    "./testing": "./src/testing/index.ts",
    "./cli": "./src/cli/index.ts",
    "./tui": "./src/tui/index.ts"
  },
  "files": [
    "src",
    "schemas",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.3.14"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "dependencies": {
    "@opentui/core": "catalog:"
  }
}
